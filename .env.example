# Single source of truth for all local secrets and dev flags. Copy to
# `.env` and fill in. Both Vite (frontend) and the FastAPI backend read
# this file:
#   - Vite reads only the `VITE_*` keys.
#   - The backend (pydantic-settings via backend/core/config.py) reads
#     OPENAI_API_KEY and any other backend overrides; non-matching keys
#     (including all VITE_*) are silently ignored.

# ── Backend ───────────────────────────────────────────────
# OpenAI key — needed for chat streaming (Phase 4) and the embed
# script (`backend/scripts/embed_knowledge_base.py`). Optional for
# Phases 1–3 (auth/leaderboard/characters/deck/match/challenge).
OPENAI_API_KEY=sk-your-key-here

# Optional backend overrides — all have defaults in
# `backend/core/config.py` so leave commented unless you need to change.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/litmatch
# CHAT_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=3072
# RAG_TOP_K=5
# DEBUG=false

# ── Frontend (Vite) ───────────────────────────────────────
# Backend base URL. Default in code is http://localhost:8081.
VITE_API_BASE_URL=http://localhost:8081

# Comma-separated whitelist of endpoints that hit the real backend
# instead of the in-memory mock. Empty string means all mock.
# Recognised keys: auth, deck, characters, match, challenge, leaderboard, chat
VITE_REAL_ENDPOINTS=auth,leaderboard,characters,deck,match,challenge,chat
