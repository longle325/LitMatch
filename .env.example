# Frontend env (Vite). Copy to `.env.local` and override locally.
# All variables MUST be prefixed `VITE_` to reach the browser.

# Backend base URL (no trailing slash). Backend listens on 8081 per
# backend/main.py. Defaults baked into code if unset.
VITE_API_BASE_URL=http://localhost:8081

# Comma-separated list of endpoints that should hit the real backend
# instead of the in-memory mock client. Anything not listed stays on
# the mock. Empty string = all mock. See src/api/adapter.ts for the
# full set of recognised keys.
#
# Recognised keys: auth, deck, characters, match, challenge, leaderboard, chat
#
# Example progressive rollout:
#   VITE_REAL_ENDPOINTS=auth,leaderboard
#   VITE_REAL_ENDPOINTS=auth,leaderboard,characters,deck
#   VITE_REAL_ENDPOINTS=auth,leaderboard,characters,deck,match,challenge,chat
VITE_REAL_ENDPOINTS=
